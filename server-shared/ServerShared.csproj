<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<RootNamespace>FOMServer.Shared</RootNamespace>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>
	
	<ItemGroup>
		<ProjectReference Include="..\fom-network\FOMNetwork.vcxproj" Condition="'$(OS)' == 'Windows_NT'" />
	</ItemGroup>

	<!-- Windows host (default) -->
	<PropertyGroup>
		<FOMNetworkLibFile>$(MSBuildThisFileDirectory)../out/build/$(Configuration)/fom-network/FOMNetwork.dll</FOMNetworkLibFile>
	</PropertyGroup>

	<!-- Linux host -->
	<PropertyGroup Condition="'$(OS)' != 'Windows_NT'">
		<FOMNetworkLibFile>$(MSBuildThisFileDirectory)../out/build/$(Configuration)/fom-network/libFOMNetwork.so</FOMNetworkLibFile>
	</PropertyGroup>

	<!-- Docker Linux -->
	<PropertyGroup Condition="'$(FOMServerBuildEnvironment)' == 'Docker'">
		<FOMNetworkLibFile>/out/cpp/build/$(Configuration)/fom-network/libFOMNetwork.so</FOMNetworkLibFile>
	</PropertyGroup>

	<!-- Include FOMNetwork -->
	<ItemGroup>
		<None Include="$(FOMNetworkLibFile)">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
	</ItemGroup>
</Project>
