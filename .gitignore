# Operating System Files
.DS_Store
Thumbs.db

# Editor Files
.vs
.vscode/*

# Keep Shared Configuration
!.vscode/tasks.json

# User Files
CMakeUserPresets.json
.claude/**/*.local.json
/local.just
/fom-docker.sh

# Build Artifacts
/out
/build

# JetBrains IDE config (per-user, not shared)
.idea/

# Ghidra Project
__pycache__/
*.pyc
*.gpr
*.rep/
*.lock
*.lock~

# RE harness: machine-specific Ghidra/JDK paths
tools/re/ghidra.local.json

# Stray top-level Obsidian vault config (real vaults are client/ and server/)
/knowledge-base/.obsidian/
# Obsidian per-user UI state (shared config app/appearance/core-plugins stays tracked)
knowledge-base/*/.obsidian/workspace.json
knowledge-base/*/.obsidian/graph.json
